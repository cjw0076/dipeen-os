# agent-client/.env — 이 PC에서 dipeen 에이전트 노드를 실행하는 설정. (커밋 금지)
# 복사: cp .env.example .env  후 값 채우기.

# ── 필수 ─────────────────────────────────────────────
DIPEEN_API_URL=http://127.0.0.1:8000     # 중앙 HQ 주소 (원격 팀: https://your-hq-domain)
DIPEEN_AGENT_ID=fe-agent                  # 이 노드의 고유 ID (팀 내 유일)
DIPEEN_AGENT_ROLE=Frontend Engineer       # 역할 (FE / BE / QA / ...)
DIPEEN_WORKSPACE=../dipeen-projects/default  # 에이전트가 작업할 프로젝트 폴더 (git repo)

# ── LLM 실행 (BYOK — 키는 이 파일에만, 서버로 전송되지 않음) ──
AGENT_USE_SUBSCRIPTION=1                   # 1 = Claude 구독으로 실행(크레딧 0). 사전에 `claude` 로그인 필요.
# ANTHROPIC_API_KEY=sk-ant-...            # 구독 대신 API 키로 과금 실행할 때만 (구독 모드면 비워두세요)
AGENT_LLM_PROVIDER=anthropic              # anthropic | openai | google
# AGENT_EXECUTOR=omo                       # oh-my-opencode(Runner)로 실행하려면. 미설치 시 claude로 fallback

# ── 팀 합류 (멀티테넌트) ─────────────────────────────
# DIPEEN_TOKEN=                            # 초대 코드로 발급받은 팀 JWT (멀티테넌트 격리)
