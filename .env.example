# ══════════════════════════════════════════════════════════
# dipeen — 환경변수 템플릿
# 사용: cp .env.example .env  (또는 .env.local)
# ══════════════════════════════════════════════════════════

# ── AI API ────────────────────────────────────────────────
# Optional for the local Control Tower / NAT demo.
# Set a real key only when you want PM Loop or provider adapters to call Anthropic.
# Leave blank for dry-run/control-plane-only startup.
ANTHROPIC_API_KEY=

# PM Agent 모델 (기본: claude-sonnet-4-6)
PM_MODEL=claude-sonnet-4-6

# PM Agent 닉네임 — agent_id가 곧 표시 이름
# 예: alice (Alice의 PM), bob-pm (Bob의 PM)
PM_AGENT_ID=pm-agent

# ── API 서버 (api/app/config.py → DIPEEN_ prefix) ─────────
# DB 파일 경로 (기본: api/dipeen.db)
# DIPEEN_DB_PATH=./dipeen.db

# 서버 바인드 (기본: 0.0.0.0:8000)
# DIPEEN_HOST=0.0.0.0
# DIPEEN_PORT=8000

# (내부) DIPEEN_DEBUG — 로컬/데모 부팅용 내부 플래그. `dipeen open`이 자동 처리하므로
# 일반 사용자는 설정할 필요 없음. 프로덕션은 항상 미설정/false.

# long-polling 대기 시간 (초)
DIPEEN_POLL_TIMEOUT=30

# JWT 시크릿 — 프로덕션 환경에서 반드시 변경
DIPEEN_SECRET_KEY=change-me-in-production

# CORS 허용 출처 (콤마 구분, "*" = 모두 허용)
# DIPEEN_CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
DIPEEN_CORS_ORIGINS=*

# 공유 컨텍스트 디렉토리 (WORKSPACE.md 저장 위치)
# DIPEEN_SHARED_DIR=/path/to/dipeen-shared

# ── PM Loop ───────────────────────────────────────────────
# PM Loop가 API에 연결할 주소 (기본: localhost:8000)
API_URL=http://localhost:8000
WS_URL=ws://localhost:8000

# PM Loop API 토큰 (인증 추가 시 사용)
# DIPEEN_API_TOKEN=

# ── 웹 프론트엔드 (Next.js) ───────────────────────────────
# 브라우저에서 직접 연결하는 주소 (Docker host 또는 VPN IP)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── Agent Client (각 PC에서 직접 실행 시) ──────────────────
# agent_id 컨벤션: {닉네임}-{역할}  예) alice-fe, bob-be, charlie-qa
# agent_id가 UI에 그대로 표시되는 닉네임이 됨 (별도 display_name 없음)
#
DIPEEN_API_URL=http://localhost:8000
DIPEEN_AGENT_ID=alice-fe
DIPEEN_AGENT_ROLE=FE
# DIPEEN_WORKSPACE=/path/to/dipeen-workspace
AGENT_MODEL=claude-sonnet-4-6
# AGENT_SKILLS=React,TypeScript,Tailwind
# AGENT_MCPS=filesystem,git

# ── LLM Provider (하나만 선택) ────────────────────────────
# AGENT_LLM_PROVIDER 값에 따라 자동으로 SDK 경로 선택:
#   anthropic   → Claude Code (opencode/claude CLI) subprocess [권장]
#   gemini      → Google Gemini via openai SDK (GEMINI_API_KEY 필요)
#   kimi        → Moonshot Kimi via openai SDK (KIMI_API_KEY 필요)
#   qwen        → Alibaba Qwen via openai SDK (QWEN_API_KEY 필요)
#   together    → Together AI via openai SDK (TOGETHER_API_KEY 필요)
#   ollama      → 로컬 Ollama (API key 불필요, 무료)
#   openai-compat → 임의 OpenAI-compatible 엔드포인트

AGENT_LLM_PROVIDER=anthropic
AGENT_MODEL=                        # 비워두면 provider 기본값 사용
#                                   # anthropic 기본: claude-sonnet-4-6 (opencode 설정 따름)
#                                   # gemini 기본: gemini-2.0-flash
#                                   # kimi 기본: kimi-k2.5
#                                   # qwen 기본: qwen2.5-coder-32b-instruct
#                                   # ollama 기본: qwen2.5-coder:32b

# Provider별 API Key (선택한 provider 것만 설정)
# ANTHROPIC_API_KEY=sk-ant-...      # anthropic 선택 시 (에이전트 본인 키, BYOK)
# GEMINI_API_KEY=AIza...            # gemini 선택 시
# KIMI_API_KEY=sk-...               # kimi 선택 시
# QWEN_API_KEY=sk-...               # qwen 선택 시
# TOGETHER_API_KEY=...              # together 선택 시
# OLLAMA_BASE_URL=http://localhost:11434/v1   # ollama (기본값)
# OPENAI_COMPAT_BASE_URL=https://api.example.com/v1  # openai-compat
# OPENAI_COMPAT_API_KEY=your-key

# ── 페르소나 설정 ──────────────────────────────────────────
# AGENT_PERSONAS=coder,reviewer     # 이 에이전트가 수행 가능한 페르소나 (콤마 구분)
#   coder     — 구현/리팩토링/디버깅 (default)
#   planner   — 설계/아키텍처
#   researcher— 조사/분석
#   reviewer  — 코드리뷰/QA
#   marketer  — 카피/마케팅

# ── Telegram (I-3, 선택적) ─────────────────────────────────
# Telegram Bot Token (BotFather에서 발급)
# TELEGRAM_BOT_TOKEN=123456789:AABBcc...
# TELEGRAM_CHAT_ID=-100123456789    # 팀 그룹 채팅 ID

# ── PostgreSQL (I-4, 프로덕션 배포 시) ────────────────────
# SQLite → PostgreSQL 마이그레이션 시 사용 (미설정 시 SQLite 사용)
# DATABASE_URL=postgresql+asyncpg://dipeen:password@localhost:5432/dipeen
# POSTGRES_PASSWORD=your-secure-db-password   # docker-compose.prod.yml용

# ── Redis (I-4, WS 수평 확장 시) ─────────────────────────
# 미설정 시 in-process 브로드캐스트 (단일 인스턴스)
# REDIS_URL=redis://localhost:6379/0

# ── 프로덕션 도메인 ────────────────────────────────────────
# nginx TLS 인증서 발급에 사용
# DOMAIN=dipeen.example.com
