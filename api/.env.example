# ══════════════════════════════════════════════════════════
# dipeen API — 환경변수 템플릿
# 사용: cp .env.example .env  (또는 .env.local)
# ══════════════════════════════════════════════════════════

# ── API 서버 (app/config.py → DIPEEN_ prefix) ─────────
# JWT 시크릿 — 프로덕션 환경에서 반드시 변경
DIPEEN_SECRET_KEY=change-me-in-production

# ── Auth ──────────────────────────────────────────────
# 프로덕션: 로그인 필수 (false = soft auth, 토큰 없어도 default-team으로 동작)
DIPEEN_REQUIRE_AUTH=true

# 개발 전용: 설정 시 GET /api/auth/dev-token 활성화 → 자동 로그인
# 프로덕션 .env에서는 반드시 제거 또는 미설정
# DIPEEN_DEV_TOKEN=changeme
